# Slaygent Communication System - Environment Variables
# Copy this file to .env and customize as needed

# Server Configuration
SLAYGENT_TTS_HOST=127.0.0.1
SLAYGENT_TTS_PORT=9003
SLAYGENT_DISCOVERY_HOST=127.0.0.1
SLAYGENT_DISCOVERY_PORT=9005

# Redis Configuration (Manual Override)
# These will be auto-detected in Clacky environment
# SLAYGENT_REDIS_HOST=127.0.0.1
# SLAYGENT_REDIS_PORT=6379
# SLAYGENT_REDIS_PASSWORD=your_password_here

# Audio Configuration
# Options: auto, sounddevice, pulse, alsa, none
SLAYGENT_AUDIO_BACKEND=auto

# Voice Configuration
SLAYGENT_DEFAULT_VOICE=amy
SLAYGENT_VOICE_DIR=voices

# Debug Mode
SLAYGENT_DEBUG=false

# Windows-specific Settings (if needed)
# SLAYGENT_WINDOWS_AUDIO_DEVICE=0
# SLAYGENT_POWERSHELL_PATH=powershell

# Development Mode Settings
# Set to true for development environments
SLAYGENT_DEV_MODE=false