#!/bin/bash
# Slaygent Communication System - Cross-platform Agent Discovery Tool
# Enhanced Bash wrapper for Python-based agent discovery

# Configuration - make this portable
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
PYTHON_SCRIPT="$SCRIPT_DIR/search-agents.py"

# Check if Python script exists
if [ ! -f "$PYTHON_SCRIPT" ]; then
    echo "❌ Error: Python script not found at $PYTHON_SCRIPT"
    echo "Make sure you're in the Slaygent Communication System directory"
    exit 1
fi

# Show help if --help requested
if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
    echo "Slaygent Communication System - Agent Discovery Tool"
    echo ""
    echo "Usage:"
    echo "  search-agents                Discover agents using server"
    echo "  search-agents --fresh        Force fresh scan"
    echo "  search-agents --direct       Use direct discovery"
    echo "  search-agents --verbose      Show detailed information"
    echo "  search-agents --statistics   Show discovery statistics"
    echo "  search-agents --status       Show server status"
    echo ""
    echo "Options:"
    echo "  --format <table|json>        Output format"
    echo "  --host <hostname>            Discovery server host"
    echo "  --port <port>                Discovery server port"
    echo "  --quiet                      Suppress output"
    echo ""
    echo "Examples:"
    echo "  search-agents"
    echo "  search-agents --verbose --fresh"
    echo "  search-agents --format json"
    echo "  search-agents --statistics"
    echo ""
    exit 0
fi

# Try different Python executables in order of preference
PYTHON_EXES=("python3" "python" "py")
PYTHON_CMD=""

for python_exe in "${PYTHON_EXES[@]}"; do
    if command -v "$python_exe" >/dev/null 2>&1; then
        # Test if it's Python 3
        if "$python_exe" -c "import sys; sys.exit(0 if sys.version_info >= (3, 8) else 1)" 2>/dev/null; then
            PYTHON_CMD="$python_exe"
            break
        fi
    fi
done

if [ -z "$PYTHON_CMD" ]; then
    echo "❌ Error: Python 3.8+ not found"
    echo "Please install Python 3.8 or later and ensure it's in your PATH"
    exit 1
fi

# Execute the Python script with all arguments
exec "$PYTHON_CMD" "$PYTHON_SCRIPT" "$@"